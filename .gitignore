# ==============================================================================
# DAPHNIA PROJECT CUSTOMIZATIONS
# Changes from Flutter defaults are documented below
# ==============================================================================

# Claude Code
# Added: Local settings are user-specific, plans are temporary
.claude/settings.local.json
.claude/plans/

# Package lock files
# Added: Library packages and their examples should not check in lock files
# See: https://dart.dev/guides/libraries/private-files#pubspeclock
pubspec.lock

# FVM (Flutter Version Management)
# Added: FVM stores Flutter SDK symlinks and cache here
.fvm/flutter_sdk
.fvm/fvm_config.json

# IDE workspace files (keep .vscode/settings.json for shared settings)
# Modified: More specific than Flutter default, allows settings.json
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml

# ==============================================================================
# FLUTTER DEFAULTS (from Flutter 3.38.0 repository)
# Do not remove or rename entries, only add new ones
# See https://github.com/flutter/flutter/issues/128635
# ==============================================================================

